# Copy to deploy/.env and fill values
DEPLOY_WEBHOOK_SECRET=replace_with_long_random_secret
DEPLOY_ALLOWED_BRANCHES=production,develop
DEPLOY_DEFAULT_BRANCH=production
DEPLOY_REPO_PATH=/var/www/html/raspberry_webinfra
DEPLOY_WEBHOOK_LOG=/var/www/html/raspberry_webinfra/deploy/logs/webhook.log
DEPLOY_RUN_LOG=/var/www/html/raspberry_webinfra/deploy/logs/deploy.log
DEPLOY_BACKUP_DIR=/var/www/html/raspberry_webinfra/deploy/backups
